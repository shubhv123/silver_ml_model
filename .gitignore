# Python
__pycache__/
*.py[cod]
*.so
.Python
env/
venv/
venv_silver/
ENV/
env.bak/
venv.bak/

# Jupyter
.ipynb_checkpoints
*.ipynb

# Data (large files - users can download themselves)
data/raw/*.csv
data/raw/*.zip
data/processed/*.csv
!data/raw/.gitkeep
!data/processed/.gitkeep
data/qlib/*.csv
data/qlib/*.zip

# Models (large binary files)
models/saved/*.pkl
models/saved/*.keras
models/saved/*.cbm
models/saved/*.nc
!models/saved/.gitkeep

# Environment variables (contains API keys)
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs and reports (optional, can be generated)
logs/
*.log
reports/figures/*.png
reports/metrics/*.csv
reports/metrics/*.json

# Temporary files
*.tmp
*.temp
debug_*.py
test_*.py

# Qlib cache
~/.qlib/
